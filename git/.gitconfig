[user]
	name = Marc Pont
	email = mpont91@gmail.com

[core]
	editor = vim
	ignorecase = false

[help]
	autocorrect = 1

[fetch]
	prune = true

[push]
	autoSetupRemote = true

[init]
	defaultBranch = master

[includeIf "gitdir:~/projects/victoria-id/"]
    path = ~/.gitconfig-victoria-id

[includeIf "gitdir:~/projects/present-connection/"]
    path = ~/.gitconfig-present-connection

[url "git@github.com-victoria-id:victoria-id/"]
    insteadOf = git@github.com:victoria-id/
    insteadOf = ssh://git@github.com/victoria-id/